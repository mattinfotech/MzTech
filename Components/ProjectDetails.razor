@* A reusable component for displaying project details *@

<section class="hero-gradient text-white py-5 shadow-sm">
    <div class="container text-center text-md-start">
        <h2 class="fw-bold mb-0">@Title</h2>
        <p class="mb-0 text-white-50">@Subtitle</p>
    </div>
</section>


<!-- Project Overview -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <!-- Image -->
            <div class="col-md-6 mb-4 mb-md-0">
                <img src="@MainImage"
                     alt="@Title App"
                     class="img-fluid rounded-4 shadow-sm" />
            </div>

            <!-- Text Content -->
            <div class="col-md-6">
                <h3 class="fw-semibold mb-3">About @Title</h3>
                <p class="text-muted">@AboutDescription</p>

                @if (!string.IsNullOrEmpty(AdditionalDescription))
                {
                    <p class="text-muted">@AdditionalDescription</p>
                }

                @if (Features?.Any() == true)
                {
                    <h5 class="fw-semibold mt-4">Key Features</h5>
                    <ul class="text-muted mb-4">
                        @foreach (var feature in Features)
                        {
                            <li>@feature</li>
                        }
                    </ul>
                }

                @if (!string.IsNullOrEmpty(TechStack))
                {
                    <h5 class="fw-semibold mt-4">Technology Stack</h5>
                    <p class="text-muted" @onclick:stopPropagation="true">
                        @((MarkupString)TechStack)
                    </p>
                }

                @if (!string.IsNullOrEmpty(ContactUrl))
                {
                    <a href="@ContactUrl" class="btn btn-primary rounded-pill mt-3 px-4">Contact Us</a>
                }
            </div>
        </div>
    </div>
</section>

<!-- Additional Images -->
@if (AdditionalImages?.Any() == true)
{
    <section class="py-5">
        <div class="container">
            <div class="text-center mb-4">
                <h4 class="fw-bold">Application Screens</h4>
                <p class="text-muted mb-0">A quick look at the @Title interface</p>
            </div>

            <div class="row g-4">
                @foreach (var img in AdditionalImages)
                {
                    <div class="col-md-4">
                        <img src="@img"
                             class="img-fluid rounded-4 shadow-sm w-100"
                             alt="@Title image" />
                    </div>
                }
            </div>
        </div>
    </section>
}
