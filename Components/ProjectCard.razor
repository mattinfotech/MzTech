@using Microsoft.AspNetCore.Components

<div class="card h-100 shadow-lg border-0 rounded-4 hover-effect">
    <img src="@ImageUrl" class="card-img-top rounded-top" alt="@Title">
    <div class="card-body p-4">
        <h5 class="card-title fw-semibold">@Title</h5>
        <p class="card-text text-muted small">@Description</p>
        <a href="@DetailsUrl" class="btn btn-outline-primary btn-sm rounded-pill mt-2">View Details</a>
    </div>
</div>

