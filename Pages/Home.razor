@page "/"
@using MzTech.Components

<PageTitle>MZ Tech</PageTitle>

<section class="hero d-flex align-items-center py-5 text-center text-md-start text-white">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-5">
                <h1 class="display-4 fw-bold mb-3 text-white">
                    Hi, I'm <span class="text-primary">Matt</span>
                </h1>
                <p class="lead mb-4 text-light">
                    A passionate software developer building modern and impactful software solutions.
                </p>
                <div class="d-flex justify-content-center justify-content-md-start gap-3">
                    <a href="#projects" class="btn btn-primary btn-lg px-4 rounded-pill">View My Work</a>
                    <a href="#contact" class="btn btn-outline-light btn-lg px-4 rounded-pill">Get In Touch</a>
                </div>
            </div>

            <div class="col-md-7 mt-5 mt-md-0 text-center">
                <img src="https://inductability.blob.core.windows.net/profile/Banner?sp=r&st=2025-08-24T13:40:55Z&se=2026-08-24T21:55:55Z&spr=https&sv=2024-11-04&sr=b&sig=Q7JdbiqvcXSbxUUbBQtbtmyAhAD0c4EDkmxytObM9jk%3D"
                     alt="Banner Image"
                     class="img-fluid w-100 rounded-3 shadow" />
            </div>
        </div>
    </div>
</section>

<!-- Projects Section -->
<section id="projects" class="py-5 bg-light">
    <div class="container">
        <!-- Section Heading -->
        <div class="text-center mb-5">
            <h2 class="fw-bold display-6">✨ Featured Projects</h2>
            <p class="text-muted fs-5">A selection of my recent works showcasing design and development skills</p>
        </div>

        <!-- Project Cards -->
        <div class="row g-4">
            <div class="col-md-4">
                 <ProjectCard 
                    Title="Lending Fabric"
                    Description="A Lending Fabric is a refinance application software that streamlines loan processing,
                            improves efficiency, and simplifies refinancing for lenders and borrowers."
                             ImageUrl="https://inductability.blob.core.windows.net/profile/LF-DealUser.png?sp=r&st=2025-10-12T06:52:03Z&se=2026-10-12T15:07:03Z&spr=https&sv=2024-11-04&sr=b&sig=KvUYi7nODcYb02Az57VPhF29vzZaIYmSzy4DQbVTrqo%3D"
                             DetailsUrl="/lending-fabric" />
            </div>

            <div class="col-md-4">
                <ProjectCard Title="Teambridg Tracker"
                    Description="Team Bridg Tracker is a project management tool that streamlines collaboration, monitors progress,
                        and boosts productivity through effective communication and task tracking."
                    ImageUrl="https://inductability.blob.core.windows.net/profile/Teambridg%2B1%20(1).png?sp=r&st=2025-08-24T14:13:28Z&se=2026-08-24T22:28:28Z&spr=https&sv=2024-11-04&sr=b&sig=5ea8u7TCjjGxhLP0LdVtpT95YU0QaCrIk2jMfYOA3RM%3D"
                    DetailsUrl="/teambridg-tracker" />
               
            </div>

            <div class="col-md-4">
                <ProjectCard Title="DealerIQ"
                             Description="DealeIQ is a software solution for car dealerships that streamlines sales, service operations, and customer call management."
                             ImageUrl="https://inductability.blob.core.windows.net/profile/SalesIQ-1.png?sp=r&st=2025-09-07T06:13:32Z&se=2026-09-07T14:28:32Z&spr=https&sv=2024-11-04&sr=b&sig=QidpJRQ61Vl%2BWqKJMkXigOiU%2B%2FJpYZKlu0TuTDZN4zc%3D"
                             DetailsUrl="/dealeriq" />
            </div>
           
            <!-- Hidden Projects (collapse) -->
            <div class="collapse mt-4" id="moreProjects">
                <div class="row g-4">
                    <div class="col-md-4">
                        <ProjectCard Title="Inductability"
                                     Description="Inductability is a comprehensive platform that simplifies employee onboarding, enhances training, and allows the creation of custom induction modules and questionnaires."
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/inductability.png?sp=r&st=2025-08-24T14:19:40Z&se=2026-08-24T22:34:40Z&spr=https&sv=2024-11-04&sr=b&sig=Q173U9NlP8zQYKlp9wBPf3uP78uf%2FwhwAStr3qMXbtw%3D"
                                     DetailsUrl="/inductability" />
                    </div>


                    <div class="col-md-4">
                        <ProjectCard Title="Rental Manager Xpress (RMX)"
                                     Description="RMX is a rental management software designed to simplify and streamline property rentals, specifically tailored for RV owners."
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/Scheduler.jpg?sp=r&st=2025-09-07T06:16:38Z&se=2026-09-07T14:31:38Z&spr=https&sv=2024-11-04&sr=b&sig=uEhAaTQdzFSScK1zAbuXm%2BanMnfLbRu4fBr8gm1fjno%3D"
                                     DetailsUrl="/rmx" />
                    </div>

                    <div class="col-md-4">
                        <ProjectCard Title="Owners Rental Program (ORP)"
                                     Description="ORP is a rental management solution designed for RV owners, helping them efficiently manage properties, track rentals, and generate detailed statements"
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/ORp.jpg?sp=r&st=2025-09-07T06:18:10Z&se=2026-09-07T14:33:10Z&spr=https&sv=2024-11-04&sr=b&sig=uoKC1IP51UjBzSgVJosIblQCoboRVXnCj6rlATq6bps%3D"
                                     DetailsUrl="/orp" />
                    </div>
                    <div class="col-md-4">
                        <ProjectCard Title="McCue"
                                     Description="McCue is a software solution that manages inventory and generates sales and service order reports for industrial safety equipment."
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/mccue.png?sp=r&st=2025-09-07T13:15:17Z&se=2026-09-07T21:30:17Z&spr=https&sv=2024-11-04&sr=b&sig=La8R4mPazHaXh9w9FDMIQ3TkJtcGWMRNG8%2FNXcJG4hk%3D"
                                     DetailsUrl="/mccue" />
                    </div>
                    <div class="col-md-4">
                        <ProjectCard Title="ProdTrac"
                                     Description="ProdTrac is a production tracking software that monitors and manages the progress and completion of building projects."
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/actual.png?sp=r&st=2025-09-07T13:16:33Z&se=2026-09-07T21:31:33Z&spr=https&sv=2024-11-04&sr=b&sig=lCDiH99m8AC1XApwuADstTpkfNy%2Fhd6G2mgxjNuF5vc%3D"
                                     DetailsUrl="/prodtrac" />
                    </div>

                    <div class="col-md-4">
                        <ProjectCard Title="VisionUnlocked"
                                     Description="VisionUnlocked is a platform designed for optometrists to manage patient appointments, records, and questionnaires efficiently."
                                     ImageUrl="https://inductability.blob.core.windows.net/profile/visionunlocked.png?sp=r&st=2025-09-07T13:59:58Z&se=2026-09-07T22:14:58Z&spr=https&sv=2024-11-04&sr=b&sig=uKELzilHsPnpkTL83EiH0rUslVRnaLSK3aW5E6Gl1pY%3D"
                                     DetailsUrl="/visionunlocked" />
                    </div>
                </div>
            </div>

            <!-- Show More Button -->
            <div class="text-center mt-4">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#moreProjects" aria-expanded="false" aria-controls="moreProjects">
                    Show More Projects
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-9">
                <div class="card shadow-sm border-0 rounded-4 p-4">
                    <h5 class="fw-semibold mb-3 text-center">Send Me a Message</h5>
                    <form action="https://formspree.io/f/mjkaaljq" method="POST">
                        <div class="mb-3">
                            <label for="name" class="form-label fw-semibold">Full Name</label>
                            <input type="text" id="name" name="name" class="form-control" placeholder="Your name" required />
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Email Address</label>
                            <input type="email" id="email" name="_replyto" class="form-control" placeholder="you@example.com" required />
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label fw-semibold">Message</label>
                            <textarea id="message" name="message" class="form-control" rows="5" placeholder="Type your message here..." required></textarea>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="fas fa-paper-plane me-2"></i> Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
