@page "/about"

<section class="hero-gradient text-white py-5 shadow-sm">
    <div class="container text-center text-md-start">
        <h2 class="fw-bold mb-0">About MZ Tech</h2>
        <p class="mb-0 text-white-50">Innovative business software solutions for modern enterprises</p>
    </div>
</section>

<!-- About Section -->
<section class="py-5 bg-light">
    <div class="container">

        <!-- Banner Image -->
        <div class="text-center mb-5">
            <img src="https://inductability.blob.core.windows.net/profile/Banner?sp=r&st=2025-08-24T13:40:55Z&se=2026-08-24T21:55:55Z&spr=https&sv=2024-11-04&sr=b&sig=Q7JdbiqvcXSbxUUbBQtbtmyAhAD0c4EDkmxytObM9jk%3D"
                 alt="About MZ Tech"
                 class="img-fluid rounded-4 shadow-lg w-100"
                 style="max-height: 420px; object-fit: cover;" />
        </div>

        <!-- About Content -->
        <div class="col-lg-10 mx-auto">
            <div class="text-center mb-4">
                <h3 class="fw-bold mb-3 text-primary">Who We Are</h3>
                <p class="text-muted fs-5">
                    MZ Tech is a software development company focused on creating innovative, scalable, and secure solutions
                    that empower businesses to improve efficiency and achieve operational excellence.
                </p>
                <p class="text-muted fs-5">
                    With expertise in <strong>Blazor WebAssembly</strong>, <strong>ASP.NET Core</strong>, and
                    <strong>Azure Cloud</strong>, we design modern, cloud-ready systems that meet the specific needs
                    of industries ranging from manufacturing to healthcare and finance.
                </p>
            </div>

            <div class="text-center mb-4">
                <h4 class="fw-semibold mt-4 text-primary">Our Mission</h4>
                <p class="text-muted fs-5">
                    To deliver intelligent, reliable, and user-centric software that transforms how businesses operate,
                    collaborate, and grow.
                </p>
            </div>

            <div>
                <h4 class="fw-semibold mt-4 text-primary text-center">Our Core Values</h4>
                <ul class="text-muted fs-5 mt-3 list-unstyled text-center">
                    <li>💡 Innovation and continuous improvement</li>
                    <li>🔒 Commitment to quality and security</li>
                    <li>🤝 Transparency and collaboration</li>
                    <li>🌐 Long-term client partnerships</li>
                </ul>
            </div>
        </div>
    </div>
</section>


<section class="py-5">
    <div class="container text-center">
        <h4 class="fw-bold mb-3">Let’s Build the Future Together</h4>
        <p class="text-muted mb-4">
            Whether you need a tailored enterprise system, a cloud-based integration platform, or a complete digital transformation —
            MZ Tech is ready to help.
        </p>
        <a href="/contact" class="btn btn-primary rounded-pill px-4">Contact Us</a>
    </div>
</section>
