@page "/about"

<section class="hero-gradient text-white py-5 shadow-sm">
    <div class="container text-center text-md-start">
        <h2 class="fw-bold mb-0">About MZ Tech</h2>
        <p class="mb-0 text-white-50">Innovative business software solutions for modern enterprises</p>
    </div>
</section>

<!-- About Section -->
<section class="py-5 bg-light">
    <div class="container">

        <!-- Banner Image -->
        <div class="text-center mb-5">
            <img src="https://inductability.blob.core.windows.net/profile/Banner?sp=r&st=2025-08-24T13:40:55Z&se=2026-08-24T21:55:55Z&spr=https&sv=2024-11-04&sr=b&sig=Q7JdbiqvcXSbxUUbBQtbtmyAhAD0c4EDkmxytObM9jk%3D"
                 alt="About MZ Tech"
                 class="img-fluid rounded-4 shadow-lg w-100"
                 style="max-height: 420px; object-fit: cover;" />
        </div>

        <!-- About Content -->
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="mb-5">
                    <h3 class="fw-bold mb-3 text-primary">Who I Am</h3>
                    <p class="text-muted fs-5">
                        I’m a software developer passionate about creating innovative, scalable, and secure solutions
                        that help businesses improve efficiency and achieve operational excellence.
                    </p>
                    <p class="text-muted fs-5">
                        With expertise in <strong>DevExpress XAF Blazor</strong>, <strong>WinForms</strong>,
                        <strong>ASP.NET Core</strong>, <strong>.NET technologies</strong>, and <strong>Azure Cloud</strong>,
                        I design and build modern, cloud-ready systems tailored to the unique needs of each project and client.
                    </p>
                </div>

                <div class="mb-5">
                    <h4 class="fw-semibold text-primary">My Mission</h4>
                    <p class="text-muted fs-5 mb-0">
                        My mission is to deliver intelligent, reliable, and user-centric software that transforms how businesses operate,
                        collaborate, and grow through technology.
                    </p>
                </div>

                <div>
                    <h4 class="fw-semibold text-primary mb-3">My Core Values</h4>
                    <ul class="text-muted fs-5 mt-2 list-unstyled">
                        <li class="mb-2">💡 Continuous innovation and learning</li>
                        <li class="mb-2">🔒 Commitment to quality and security</li>
                        <li class="mb-2">🤝 Transparency and collaboration</li>
                        <li>🌐 Building long-term client partnerships</li>
                    </ul>
                </div>
            </div>
        </div>

    </div>
</section>

<!-- CTA Section -->
<section class="py-5 hero-gradient text-white text-center text-md-start">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h4 class="fw-bold mb-3">Let’s Build the Future Together</h4>
                <p class="text-white-50 mb-0">
                    Whether you need a tailored enterprise system, a cloud-based integration platform,
                    or a complete digital transformation — MZ Tech is ready to help.
                </p>
            </div>
            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                <a href="/contact" class="btn btn-light text-primary fw-semibold rounded-pill px-4 py-2 shadow-sm">
                    Contact Me
                </a>
            </div>
        </div>
    </div>
</section>
