@page "/contact"

<!-- Contact Banner -->
<section class="bg-primary text-white py-5 shadow-sm">
    <div class="container text-center">
        <h2 class="fw-bold mb-2">Contact Us</h2>
        <p class="text-white-50 mb-0">We’d love to hear from you — let’s build something amazing together.</p>
    </div>
</section>

<!-- Contact Form Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center align-items-center">
            <!-- Contact Info -->
            <div class="col-lg-5 mb-4 mb-lg-0">
                <h4 class="fw-bold text-primary mb-3">Get in Touch</h4>
                <p class="text-muted">
                    Whether you have a question, want to request a demo, or discuss your next project — feel free to reach out.
                </p>

                <ul class="list-unstyled text-muted mb-4">
                    <li class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i> hello@mztech.com</li>
                    <li class="mb-2"><i class="fas fa-phone me-2 text-primary"></i> +63 912 345 6789</li>
                    <li><i class="fas fa-map-marker-alt me-2 text-primary"></i> Davao City, Philippines</li>
                </ul>

                <div class="d-flex gap-3 mt-4">
                    <a href="https://facebook.com" target="_blank" class="text-primary fs-4"><i class="fab fa-facebook"></i></a>
                    <a href="https://linkedin.com" target="_blank" class="text-primary fs-4"><i class="fab fa-linkedin"></i></a>
                    <a href="https://github.com" target="_blank" class="text-primary fs-4"><i class="fab fa-github"></i></a>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 rounded-4 p-4">
                    <h5 class="fw-semibold mb-3 text-center">Send Us a Message</h5>
                    <form action="https://formspree.io/f/mjkaaljq" method="POST">
                        <div class="mb-3">
                            <label for="name" class="form-label fw-semibold">Full Name</label>
                            <input type="text" id="name" name="name" class="form-control" placeholder="Your name" required />
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Email Address</label>
                            <input type="email" id="email" name="_replyto" class="form-control" placeholder="you@example.com" required />
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label fw-semibold">Message</label>
                            <textarea id="message" name="message" class="form-control" rows="5" placeholder="Type your message here..." required></textarea>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="fas fa-paper-plane me-2"></i> Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
